{
  "name": "yesplaymusic",
  "version": "0.4.10",
  "private": true,
  "description": "A third party music player for Netease Music",
  "author": "qier222<qier222@outlook.com>",
  "scripts": {
    "serve": "vite --host 0.0.0.0",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint ./src --ext .js,.vue",
    "electron:build": "cross-env IS_ELECTRON=true vite build && electron-builder -p never",
    "electron:build-all": "cross-env IS_ELECTRON=true vite build && electron-builder -p never -mwl",
    "electron:build-mac": "cross-env IS_ELECTRON=true vite build && electron-builder -p never -m",
    "electron:build-win": "cross-env IS_ELECTRON=true vite build && electron-builder -p never -w",
    "electron:build-linux": "cross-env IS_ELECTRON=true vite build && electron-builder -p never -l",
    "electron:serve": "cross-env IS_ELECTRON=true vite --host 0.0.0.0",
    "electron:publish": "cross-env IS_ELECTRON=true vite build && electron-builder -mwl -p always",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps",
    "prettier": "npx prettier --write ./src",
    "netease_api:run": "npx @neteasecloudmusicapienhanced/api",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "main": "dist-electron/background.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@neteasecloudmusicapienhanced/api": "^4.32.0",
    "@tanstack/vue-virtual": "^3.13.24",
    "@unblockneteasemusic/rust-napi": "^0.4.0",
    "@vue/compat": "3.5.33",
    "axios": "^1.15.2",
    "change-case": "^4.1.2",
    "cli-color": "^2.0.0",
    "color": "^4.2.3",
    "crypto-js": "^4.0.0",
    "dayjs": "^1.8.36",
    "dexie": "^3.0.3",
    "discord-rich-presence": "^0.0.8",
    "electron-devtools-installer": "^3.2",
    "electron-store": "^8.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.17.1",
    "express-http-proxy": "^1.6.2",
    "howler": "^2.2.3",
    "jsbi": "^4.1.0",
    "lodash": "^4.17.23",
    "lodash-es": "^4.18.1",
    "md5": "^2.3.0",
    "mpris-service": "^2.1.2",
    "music-metadata": "^11.12.3",
    "node-vibrant": "^4.0.4",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "plyr": "^3.6.2",
    "qrcode": "^1.4.4",
    "vscode-codicons": "^0.0.17",
    "vue": "3.5.33",
    "vue-gtag-next": "^1.14.0",
    "vue-i18n": "^11.4.0",
    "vue-router": "^4.6.4",
    "vue-slider-component": "^4.1.0-beta.7",
    "x11": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-sfc": "3.5.33",
    "@vue/test-utils": "^2.4.8",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.6.0",
    "fast-glob": "^3.3.3",
    "globals": "^16.5.0",
    "husky": "^4.3.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "sass": "^1.96.0",
    "vite": "^7.3.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vitest": "^4.1.5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "npm run prettier"
    }
  },
  "build": {
    "appId": "com.qier222.yesplaymusic",
    "productName": "YesPlayMusic",
    "copyright": "Copyright © YesPlayMusic",
    "asar": true,
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "hacksynth",
        "repo": "YesPlayMusic",
        "vPrefixedTagName": true,
        "releaseType": "draft"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64",
            "universal"
          ]
        }
      ],
      "artifactName": "${productName}-${os}-${version}-${arch}.${ext}",
      "category": "public.app-category.music",
      "darkModeSupport": true
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico",
      "publish": [
        "github"
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "armv7l",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "pacman",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Music",
      "icon": "./build/icon.icns"
    },
    "dmg": {
      "icon": "build/icons/icon.icns"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "overrides": {
    "nan": "2.26.2"
  }
}
